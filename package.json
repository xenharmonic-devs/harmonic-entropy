{
  "name": "harmonic-entropy",
  "version": "0.2.2",
  "description": "Compute harmonic entropy of a musical interval",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/frostburn"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "keywords": [
    "xenharmonic",
    "music",
    "harmonic",
    "entropy"
  ],
  "author": "Lumi Pakkanen",
  "homepage": "https://github.com/xenharmonic-devs/harmonic-entropy#readme",
  "bugs": {
    "url": "https://github.com/xenharmonic-devs/harmonic-entropy/issues"
  },
  "scripts": {
    "test": "vitest",
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "bench": "vitest bench",
    "doc": "typedoc src/index.ts --name harmonic-entropy"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "gts": "^7.0.0",
    "jsdom": "^29.0.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "frost-fft": "^0.3.0",
    "xen-dev-utils": "^0.12.0"
  }
}
